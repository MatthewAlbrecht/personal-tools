            <li class="hierarchy_list_item">
               <div class="hierarchy_list_item_details">
                  <a href="/genre/xaxado/">Xaxado</a>
                  <p>Features a strong rhythmic beat, sliding tap dances, and stories of backland bandits.</p>
               </div>
         
         
            </li>
         </ul>
         
            </li>
         </ul>
                  
         <ul class="hierarchy_list">
